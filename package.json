{
    "name":  "event-management-portal",
    "version":  "1.0.0",
    "private":  true,
    "scripts":  {
                    "start":  "node server.js",
                    "server":  "node server.js",
                    "client":  "npm.cmd run dev --prefix client",
                    "dev":  "concurrently -n API,CLIENT -c green,cyan \"npm.cmd run server\" \"npm.cmd run client\"",
                    "build":  "npm.cmd run build --prefix client"
                },
    "dependencies":  {
                         "axios":  "^1.18.1",
                         "bcryptjs":  "^3.0.3",
                         "express":  "^5.2.1",
                         "jsonwebtoken":  "^9.0.3",
                         "jwt-decode":  "^4.0.0",
                         "mongoose":  "^9.7.2",
                         "react-router-dom":  "^7.18.0"
                     },
    "devDependencies":  {
                            "concurrently":  "^10.0.3"
                        }
}
